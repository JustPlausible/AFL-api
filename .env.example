# General
ENVIRONMENT=development
LOG_LEVEL=INFO

# Admin UI
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
SESSION_SECRET=replace-with-a-long-random-secret

# Database
DB_PATH=data/afl_players.db

# AFL site configuration
AFL_COMPETITION_ID=1
AFL_SEASON_ID=73
AFL_SEASON_PID=CD_S2025014
AFL_BASE_URL=https://www.afl.com.au

# Scraper behavior
SCRAPER_TIMEOUT=10

# Optional local Compose ports
AFL_API_PORT=8000
AFL_ADMIN_PORT=8001
